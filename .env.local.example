# ─────────────────────────────────────────────────────────────
# HOET Work Report — Environment
# ─────────────────────────────────────────────────────────────
#
# LOCAL DEMO MODE (default):
#   Leave these BLANK. The app runs entirely in the browser using
#   localStorage, with live cross-tab sync. Great for localhost /
#   trying it out. `npm run dev` just works.
#
# PRODUCTION MODE (Vercel + shared live data across devices):
#   Fill these in from your Supabase project
#   (Project Settings → API). Then the app uses the shared cloud
#   database with real auth + realtime.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only, used ONLY by `npm run seed` to create user accounts.
# NEVER commit this or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Default password given to every seeded account (they can change later).
SEED_DEFAULT_PASSWORD=Hoet@2026
